        "block_type": "HttpRequest",
        "label": "Loopback request",
        "disabled": false,
        "safe_mode": false,
        "settings": {
          "type": "HttpRequest",
          "method": "GET",
          "url": "__TARGET_URL__/api/check?id=<input.USER>&delay_ms=__DELAY_MS__",
          "headers": [["Accept", "application/json"]],
          "body": "",
          "body_type": "None",
          "content_type": "application/json",
          "follow_redirects": true,
          "max_redirects": 2,
          "timeout_ms": 10000,
          "auto_redirect": true,
          "basic_auth": null,
          "http_version": "HTTP/1.1",
